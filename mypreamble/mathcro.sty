%stacked customizable versions
\newcommand{\@rrowhead}{\mathchoice%
    {\mkern-12mu\@rdarrow}%
    {\mkern-12mu\@rdarrow}%
    {\mkern-11mu\@rdarrow}%
    {\mkern-10mu\@rdarrow}%
}
\newcommand{\epi@rrowhead}{\mathchoice%
    {\mkern-12mu\mathord{\twoheadrightarrow}}%
    {\mkern-12mu\mathord{\twoheadrightarrow}}%
    {\mkern-11mu\mathord{\twoheadrightarrow}}%
    {\mkern-10mu\mathord{\twoheadrightarrow}}%
}
\newcommand{\xr@lbar}[2]{%
    \sbox0{$\m@th#1#2$}%
    \dimen@=\wd0%
    \advance\dimen@ by 2em %
    \sbox1{%
        \hbox to \dimen@{%
            \cleaders\hbox{$\m@th#1\mkern-2.5mu\@rdminus\mkern-2.5mu$}\hfill%
        }%
    }%
    \clipbox{1em 0pt 1em 0pt}{\copy1}%
}
\newcommand{\xmono}[1][\mkern2mu]{\mathrel{%
    \mathord{\lhook}\mkern-1.8mu%
    \mathord{\mathop{\mathpalette\xr@lbar{#1}}\limits^{#1}}%
    \@rrowhead%
    }%
}
\newcommand{\xto}[1][\mkern2mu]{\mathrel{%
    \mkern2.5mu\mathrlap{\mkern-2.5mu\relbar}%
    \mathord{\mathop{\mathpalette\xr@lbar{#1}}\limits^{#1}}%
    \@rrowhead%
    }%
}
\newcommand{\xepi}[1][\mkern2mu]{\mathrel{%
    \mkern2.5mu\mathrlap{\mkern-2.5mu\relbar}%
    \mathord{\mathop{\mathpalette\xr@lbar{#1}}\limits^{#1}}%
    \epi@rrowhead%
    }%
}
\newcommand{\xwto}[1][\mkern2mu]{\mathrel{\mathpalette\@xwto{#1}}}
    \newcommand*{\@xwto}[2]{%
        \sbox0{$\m@th#1\xto[#2]$}%
        \sbox1{$\m@th#1\circ$}%
        \dimen@=\wd0%
        \advance\dimen@ by -\wd1 %
        \divide\dimen@ by 2 %
        \rlap{%
            \hskip\dimen@\hbox{$\m@th#1\circ$}
        }%
        \copy0
    }
