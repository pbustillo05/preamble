%long versions
\newcommand*{\longeq}{\mathrel{\@isomorphism}}
    \newcommand*{\@isomorphism}{%
      % Calculate the amount of moving \sim up as in \simeq
      \sbox0{$\simeq$}%
      \sbox1{$\sim$}%
      \dimen@=\ht0 %
      \advance\dimen@ by -\ht1 %
      %
      % Compose the two symbols
      \sbox0{%
        \lower1.9\dimen@\hbox{%
          $\longrightarrow$%
        }%
      }%
      \rlap{%
        \hbox to \wd0{%
          \hfill\raise\dimen@\hbox{$\sim$}\hfill
        }%
      }%
      \copy0 %
    }
