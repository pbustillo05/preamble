%%%%% DEFINITION AND REMARK ENVIRONMENTS LAYOUT (using amsthm)
\usepackage{amsthm}   %theorem environments

\usepackage[framemethod=tikz]{mdframed}     %bars left to def/rem, from Quiangru but has bad break yellow warning problem
    \mdfdefinestyle{leftbar}{
      linewidth=1.5pt,
      linecolor=gray,
      hidealllines=true,
      leftline=true,
      leftmargin=0pt,
      innerleftmargin=5pt,
      innerrightmargin=10pt,
      innertopmargin=-5pt,
      innerbottommargin=0pt
    }

\theoremstyle{definition}
\begingroup
    \newtheorem{definition}{Definition}[section]
    \newtheorem{convention}{Convention}[section]
    \newtheorem{notation}[convention]{Notation}
    \newtheorem{conjecture}{Conjecture}[section]
    \newtheorem{assumption}{Assumption}[section]
\endgroup
\surroundwithmdframed[style=leftbar]{definition}
\surroundwithmdframed[style=leftbar]{convention}
\surroundwithmdframed[style=leftbar]{conjecture}
\surroundwithmdframed[style=leftbar]{assumption}
\surroundwithmdframed[style=leftbar]{notation}

\theoremstyle{remark}
\begingroup
    \newtheorem{remark}{Remark}[section]
    \newtheorem{construction}[remark]{Construction}
    \newtheorem{observation}[remark]{Observation}
\endgroup

%%%% THEOREM ENVIRONMENTS LAYOUT (using thmbox,boites) => could be worth it to just copy what I want from the package
\usepackage{calc}
\usepackage{thmbox}
\thmboxoptions{headstyle={\bfseries#1 #2~},thickness=0.6pt, cut=false}
\usepackage{boites}

\renewcommand\thmbox@titlestyle[1]{(#1)}
\newlength{\temp@thmbox@emul}

\def\thmbox@begin#1#2#3{%
    \ifhmode\unskip\unskip\par\fi
    \vskip\topsep
    \refstepcounter{#2}%
    \thmbox{\thmbox@headstyle{#1}{\csname the#2\endcsname}#3}%
    \thmbox@bodystyle\ignorespaces}     %correct top space
    
\def\thmbox#1{%
    \def\breakboxparindent{\parindent}
    \def\breakboxskip{0pt}
    \def\bkvz@before@breakbox{\ifhmode\par\fi\vskip\breakboxskip\relax}%allows for page breaks
    \def\bkvz@set@linewidth{\advance\linewidth-10.4pt
                        \advance\linewidth-0.4em}%removes space used by left bar (10pt+0.4pt+0.4em) where 0.4pt is the width of the vrule
    \def\bk@line{\hbox  to \linewidth{\bkvz@left\box\bk@bxa\bkvz@right}}%
    \def\bkvz@left{\hskip10pt\vrule\color{black}\hskip0.4em}%bar on the left side
    \def\bkvz@right{}%nothing on the right side
    \def\bkvz@top{\setlength{\temp@thmbox@emul}{\widthof{#1}}\noindent{#1}\par\nobreak\vskip2pt\hrule width \temp@thmbox@emul\color{black}\par\nobreak}%creates Title underlined in black, breaks lines without breaking pages
    \def\bkvz@bottom{}%nothing on the bottom => can be changed if desired
    \breakbox\vskip2pt\noindent\itshape\ignorespaces}%a bit of space before the start of the first line
    
\def\endthmbox{\endbreakbox}

\def\thmbox@new#1#2#3#4{%
    \expandafter\def\csname#2\endcsname{%
        \setkeys{thmbox}{#1}%
        \@ifnextchar[{\thmbox@beginA{#3}{#4}}{%
            \thmbox@begin{#3}{#4}{}}%
    }%
    \expandafter\def\csname end#2\endcsname{%
        \endthmbox\vskip\topsep%
    }%
}
%PROBLEMS: systematic "Underfull \hbox (badness 10000) detected" when "enumerate" inside such a theorem environment => doesn't look bad so it's probably fine

\newtheorem{lemma}{\noindent Lemma}[section]
\newtheorem{proposition}[lemma]{\noindent Proposition}
\newtheorem{theorem}[lemma]{\noindent Theorem}
\newtheorem{corollary}{\noindent Corollary}[lemma]

\def\exercise{}
\@ifundefined{exercisename}{\def\exercisename{Exercise}}{}
\renewenvironment{exercise}[1][\exercisename]{%
  \par\smallbreak\small%
  \list{\hspace\labelsep\textbf{#1\,:}}{%
    \leftmargin=\parindent%
    \labelwidth=\parindent}%
  \item\relax}{%
  \endlist}
\def\openquestion{}
\@ifundefined{openquestionname}{\def\openquestionname{Open Question}}{}
\renewenvironment{openquestion}[1][\openquestionname]{%
  \par\smallbreak\small%
  \list{\hspace\labelsep\textbf{#1\,:}}{%
    \leftmargin=\parindent%
    \labelwidth=\parindent}%
  \item\relax}{%
  \endlist}