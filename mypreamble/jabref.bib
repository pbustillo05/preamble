@Article{JS17,
  author    = {Johnson-Freyd, Theo and Scheimbauer, Claudia},
  journal   = {Advances in Mathematics},
  title     = {{(Op)}lax {N}atural {T}ransformations, {T}wisted {Q}uantum {F}ield {T}heories, and “even {H}igher” {M}orita {C}ategories},
  year      = {2017},
  issn      = {0001-8708},
  month     = feb,
  pages     = {147-223},
  volume    = {307},
  abstract  = {Motivated by the challenge of defining twisted quantum field theories in the context of higher categories, we develop a general framework for lax and oplax transformations and their higher analogs between strong (∞,n)-functors. We construct a double (∞,n)-category built out of the target (∞,n)-category governing the desired diagrammatics. We define (op)lax transformations as functors into parts thereof, and an (op)lax twisted field theory to be a symmetric monoidal (op)lax natural transformation between field theories. We verify that lax trivially-twisted relative field theories are the same as absolute field theories. As a second application, we extend the higher Morita category of Ed-algebras in a symmetric monoidal (∞,n)-category C to an (∞,n+d)-category using the higher morphisms in C.},
  doi       = {https://doi.org/10.1016/j.aim.2016.11.014},
  file      = {:(JS17) Johnson-FreydScheimbauer - (Op)lax Natural Transformations, Twisted Quantum Field Theories, and “even Higher” Morita Categories.pdf:PDF},
  keywords  = {Higher category theory, Extended TFTs},
  publisher = {Elsevier BV},
  url       = {https://www.sciencedirect.com/science/article/pii/S0001870816303164},
}

@Article{GS16,
  author    = {Garner, Richard and Shulman, Michael},
  journal   = {Advances in Mathematics},
  title     = {Enriched {C}ategories as a {F}ree {C}ocompletion},
  year      = {2016},
  issn      = {0001-8708},
  month     = feb,
  pages     = {1-94},
  volume    = {289},
  abstract  = {This paper has two objectives. The first is to develop the theory of bicategories enriched in a monoidal bicategory—categorifying the classical theory of categories enriched in a monoidal category—up to a description of the free cocompletion of an enriched bicategory under a class of weighted bicolimits. The second objective is to describe a universal property of the process assigning to a monoidal category V the equipment of V-enriched categories, functors, transformations, and modules; we do so by considering, more generally, the assignation sending an equipment C to the equipment of C-enriched categories, functors, transformations, and modules, and exhibiting this as the free cocompletion of a certain kind of enriched bicategory under a certain class of weighted bicolimits.},
  doi       = {https://doi.org/10.1016/j.aim.2015.11.012},
  file      = {:(GS16) GarnerShulman - Enriched Categories As a Free Cocompletion.pdf:PDF},
  keywords  = {Enriched bicategory theory, Enriched categories, Free cocompletions, Equipments},
  publisher = {Elsevier BV},
  url       = {https://www.sciencedirect.com/science/article/pii/S0001870815004715},
}

