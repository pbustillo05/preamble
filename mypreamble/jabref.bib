@Article{Tom18,
  author        = {Tommasini, Matteo},
  journal       = {Journal of Pure and Applied Algebra},
  title         = {Right {S}aturations and {I}nduced {P}seudofunctors between {B}icategories of {F}ractions},
  year          = {2018},
  issn          = {0022-4049},
  month         = feb,
  number        = {2},
  pages         = {241-290},
  volume        = {222},
  abstract      = {We fix any bicategory A together with a class of morphisms WA, such that there is a bicategory of fractions A[WA−1] (as described by D. Pronk). Given another such pair (B,WB) and any pseudofunctor F:A→B, we find necessary and sufficient conditions in order to have an induced pseudofunctor G:A[WA−1]→B[WB−1]. Moreover, we give a simple description of G in the case when the class WB is “right saturated”.},
  archiveprefix = {arXiv},
  comment       = {Preprint called "Some insights on bicategories of fractions - II"},
  date          = {2014-10-19},
  doi           = {10.1016/j.jpaa.2017.03.014},
  eprint        = {1410.5075},
  eprintclass   = {math.CT},
  eprinttype    = {arXiv},
  file          = {:(Tom18) Tommasini - Right Saturations and Induced Pseudofunctors between Bicategories of Fractions.pdf:PDF},
  keywords      = {math.CT},
  primaryclass  = {math.CT},
  publisher     = {Elsevier {BV}},
  url           = {https://www.sciencedirect.com/science/article/pii/S0022404917300622},
}

@Article{Tom16,
  author        = {Tommasini, Matteo},
  journal       = {Theory and Applications of Categories},
  title         = {Some {I}nsights on {B}icategories of {F}ractions: {R}epresentations and {C}omposition of 2-{M}orphisms},
  year          = {2016},
  month         = apr,
  number        = {10},
  pages         = {257--329},
  volume        = {31},
  abstract      = {In this paper we investigate the construction of bicategories of fractions originally described by D. Pronk: given any bicategory $\mathcal{C}$ together with a suitable class of morphisms $\mathbf{W}$, one can construct a bicategory $\mathcal{C}[\mathbf{W}^{-1}]$, where all the morphisms of $\mathbf{W}$ are turned into internal equivalences, and that is universal with respect to this property. Most of the descriptions leading to this construction were long and heavily based on the axiom of choice. In this paper we considerably simplify the description of the equivalence relation on $2$-morphisms and the constructions of associators, vertical and horizontal compositions in $\mathcal{C}[\mathbf{W}^{-1}]$, thus proving that the axiom of choice is not needed under certain conditions. The simplified description of associators and compositions will also play a crucial role in two forthcoming papers about pseudofunctors and equivalences between bicategories of fractions.},
  archiveprefix = {arXiv},
  date          = {2014-10-15},
  eprint        = {1410.3990v3},
  eprintclass   = {math.CT},
  eprinttype    = {arXiv},
  file          = {:(Tom16) Tommasini - Some Insights on Bicategories of Fractions - Representations and Composition of 2-Morphisms.pdf:PDF},
  keywords      = {math.CT},
  primaryclass  = {math.CT},
  url           = {https://www.emis.de/journals/TAC/volumes/31/10/31-10abs.html},
}

