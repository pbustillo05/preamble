%%%%% ZREF IMPLEMENTATION
\usepackage{zref-base,zref-user,zref-env,zref-counter,zref-titleref}
\zref@addprop{main}{envname}
\zref@addprop{main}{envline}
\zref@newprop{Envname}[]{\xmakefirstuc\@currenvir}
\zref@addprop{main}{Envname}
% main porperty list now contains: default (numbering), page (page number), counter (name of shared counter), title (title in []), envname (name of environment), envline (line of environement)
% available commands are: zlabel, zref, zpageref, ztitleref, ztitlerefsetup

\newcommand*{\mylabel}[1]{%
    \Hy@raisedlink{\myanchor{#1}}%
    \zlabel{#1}%
}
\newcommand*{\refnumber}[1]{%
    \gotoanchor{#1}{%
    \zref{#1}%
}}
\newcommand*{\refnamenumber}[1]{\gotoanchor{#1}{%
    \zref[envname]{#1}~\zref{#1}%
}}
\newcommand*{\refNamenumber}[1]{\gotoanchor{#1}{%
    \zref[Envname]{#1}~\zref{#1}%
}}
\newcommand*{\reftitleNamenumber}[1]{\gotoanchor{#1}{%
    \zref[title]{#1}~(\zref[Envname]{#1}~\zref{#1})%
}}
\newcommand*{\reftitlenamenumber}[1]{\gotoanchor{#1}{%
    \zref[title]{#1}~(\zref[envname]{#1}~\zref{#1})%
}}
\newcommand*{\refNamenumbertitle}[1]{\gotoanchor{#1}{%
    \zref[Envname]{#1}~\zref{#1}~(\zref[title]{#1})%
}}
\newcommand*{\refnamenumbertitle}[1]{\gotoanchor{#1}{%
    \zref[envname]{#1}~\zref{#1}~(\zref[title]{#1})%
}}
\newcommand*{\equationref}[1]{\gotoanchor{#1}{%
    (\zref{#1})%
}}

%%%%% HYPER-WORDS: axioms and concepts
\def\newhyperconcept#1#2{%
    \newcounter{#2}
    \expandafter\def\csname #2target\endcsname##1##2{%
        \stepcounter{#2}%
        \def\@currentlabel{{#1##1}}%create name visible when referecing
        \mylabel{##1}%
        \acrobatgoback{#1##2}%create name visible at target
    }
    \expandafter\newcommand\csname #2\endcsname[2][\relax]{%
        \if##1\relax{%
            \csname #2target\endcsname{##2}{##2}%
        }\else{%
            \csname #2target\endcsname{##1}{##2}%
        }\fi}
    \expandafter\newcommand\csname item#2\endcsname[1]{\item[\csname #2target\endcsname{##1}{##1}]}
    \expandafter\newcommand\csname ref#2\endcsname[2]{\hyperref[##1]{{#1 ##2}}}
    \expandafter\providecommand\csname #2autorefname\endcsname{#2}}
\newhyperconcept{\normalfont\bfseries}{axiom}
\newhyperconcept{}{concept}

